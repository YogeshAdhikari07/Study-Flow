<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Studyt Flow-Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/home.css">
</head>

<body class="h-screen w-screen overflow-x-hidden flex bg-[#0b0b0c] text-white">
    <section id="hero" role="form" class="h-full w-full flex justify-center items-center flex-col">
        <div class="bg-[#2b2b2b] p-2 flex justify-center items-center flex-col rounded-xl">
            <h1 class="p-4 border-b-2 text-3xl font-bold text-center">STUDY FLOW</h1>
            <form id="loginForm" class="flex flex-col gap-4 p-2">
                <label for="displayname">DISPLAY NAME :</label>
                <input type="text" name="displayname" id="displayname" autocomplete="username" placeholder="DISPLAY NAME" required="required" class="p-2 flex justify-center outline-none border-1 border-[#ff6b00]">
                <label for="password">PASSWORD :</label>
                <input type="password" name="password" id="password" autocomplete="current-password" placeholder="PASSWORD" required="required" class="p-2 flex justify-center outline-none border-1 border-[#ff6b00]">
                <button type="submit" class="bg-white text-black p-4 flex justify-center items-center rounded-2xl hover:bg-[#ff6b00]">LOGIN</button>
                <span>DON'T HAVE AN ACCOUNT <a class="text-[#ff6b00]" href="/page/signup">SIGN UP</a></span>
            </form>
        </div>
    </section>
    <span id="alertbox" role="alert" class="absolute top-10 left-[50%] -translate-x-1/2 flex flex-col gap-2 " ></span>
    <script src="/javascript/login.js"></script>
</body>
</html>