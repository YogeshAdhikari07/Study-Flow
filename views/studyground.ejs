<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Flow</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/index.css">

</head>

<body class="h-screen w-screen overflow-x-hidden bg-[#0b0b0c] text-white flex flex-row p-6 gap-6">
    <section id="menu" role="menu"
        class="border-2 border-[#575656] rounded-xl hidden lg:w-[250px] lg:flex p-4 gap-4 flex-col">
        <div class="flex flex-col flex-1 gap-4">
            <span class="flex flex-row gap-2 justify-end">
                <img src="/media/close.svg" alt="Close" class="h-5 lg:hidden" id="closemenu">
            </span>
            <span class="flex flex-row gap-2" onclick="location.href='/page/home'"><img src="/media/dashboard.svg"
                    alt="Dashboard" class="h-6">
                <h1>DashBoard</h1>
            </span>
            <span class="flex flex-row gap-2 hover:cursor-pointer" onclick="location.href='/page/task'"><img
                    src="/media/task.svg" alt="Tasks" class="h-5">
                <h1>Tasks</h1>
            </span>
            <span class="flex flex-row justify-between hover:cursor-pointer">
                <span class="flex flex-row gap-2"><img src="/media/playground.svg" alt="Tasks" class="h-5">
                    <h1>StudyGround</h1>
                </span>
                <h1 class="p-1 bg-white text-black rounded-full text-xs">Beta</h1>
            </span>
            <span class="flex flex-row justify-between hover:cursor-pointer">
                <span class="flex flex-row gap-2"><img src="/media/team.svg" alt="Tasks" class="h-5">
                    <h1>Team</h1>
                </span>
                <h1 class="p-1 bg-white text-black rounded-full text-xs">Beta</h1>
            </span>
            <span class="flex flex-row justify-between hover:cursor-pointer">
                <span class="flex flex-row gap-2"><img src="/media/chat.svg" alt="Tasks" class="h-5">
                    <h1>Chat</h1>
                </span>
                <h1 class="p-1 bg-white text-black rounded-full text-xs">Beta</h1>
            </span>
        </div>
        <div class="flex flex-col gap-2">
            <span class="flex flex-row items-center gap-2"><img src="/media/setting.svg" alt="Setting" class="h-6">
                <h1>Setting</h1>
            </span>
            <span class="flex flex-row gap-2" onclick="location.href='/page/logout'"><img src="/media/logout.svg"
                    alt="Logout" class="h-6">
                <h1>Logout</h1>
            </span>
        </div>
    </section>
    <section id="hero" class="flex-1 flex flex-col gap-4 overflow-y-auto ">
        <div><span class="flex flex-row items-center gap-2">
                <img id="menubtn" src="/media/menu.svg" alt="Menu" class="h-8 lg:hidden">
                <h1 class="lg:text-xl">Study Flow</h1>
            </span></div>
        <div class="lg:grid grid-cols-2 flex flex-col gap-6" id="contentdiv">
            <div class="flex flex-col gap-4 overflow-y-auto" id="studyground">
                <div class="flex justify-center lg:justify-between items-center">
                    <!-- Search space -->
                    <span class="flex border-white border-1 py-2 px-3 gap-2 rounded-2xl">
                        <input type="text" id="searchBox" class="flex-1 outline-none">
                        <img src="/media/search.svg" alt="search" class="h-5" onclick="search()">
                    </span>
                    <!-- Grid Layout -->
                    <span class="lg:grid grid-cols-2 border-white border-1 rounded-full hidden">
                        <span class="px-4 py-2 border-r-1 border-white rounded-l-full" id="layoutfull">
                            <svg xmlns="http://www.w3.org/2000/svg" stroke="#ffffff" fill="none" stroke-width="2"
                                viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" height="24"
                                width="24" id="fullsvg">
                                <path
                                    d="M5 3m0 1a1 1 0 0 1 1 -1h12a1 1 0 0 1 1 1v16a1 1 0 0 1 -1 1h-12a1 1 0 0 1 -1 -1z" />
                            </svg>
                        </span>
                        <span class="px-4 py-2 border-l-1 border-white bg-white rounded-r-full" id="halflayout"><svg
                                xmlns="http://www.w3.org/2000/svg" stroke="#000" fill="none" stroke-width="2"
                                viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" height="24"
                                width="24" id="halfsvg">
                                <path
                                    d="M3 3m0 1a1 1 0 0 1 1 -1h16a1 1 0 0 1 1 1v16a1 1 0 0 1 -1 1h-16a1 1 0 0 1 -1 -1zm9 -1v18" />
                            </svg></span>
                    </span>
                </div>
                <div id="resultBox" class=" flex flex-col gap-4 h-auto overflow-y-auto hidden">

                </div>
                <div id="iframediv" class="hidden">
                    <iframe src="https://www.youtube.com/embed/Oe421EPjeBE" frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin" allowfullscreen class="aspect-16/9 rounded-2xl"
                        id="iframe"></iframe>
                </div>
            </div>
            <div id="tools" class="text-wrap whitespace-wrap break-all">
                tools
            </div>
        </div>
    </section>
    <script src="/javascript/studyground.js"></script>
</body>

</html>