<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Study Flow</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body class="h-auto w-screen bg-[#0b0b0c] text-white py-5 px-5 lg:px-10 flex flex-col gap-10 overflow-x-hidden">
  <nav class="w-full flex flex-row justify-between py-5 items-center">
    <span>
      <h1 class="font-bold text-2xl">Study Flow</h1>
    </span>
    <span class="h-full flex flex-row gap-3 lg:gap-10 items-center">
      <a href="https://github.com/YogeshAdhikari07/Study-Flow" target="_blank" class="text-[#cfcfcfff]">Github</a>
      <button class="bg-[#ff6b00] p-2 h-full rounded-xl flex justify-center items-center">Get Started</button>
    </span>
  </nav>
  <section id="hero" role="banner" class="flex flex-row py-5 gap-10 h-full w-full">
    <div id="hero_banner_right" class="flex flex-col justify-center items-center  lg:items-start flex-1 gap-8 h-full">
      <h1 class="text-3xl font-bold mx-auto text-center font-bold">
        Organize your coursework with ease
      </h1>
      <p class="text-[#cfcfcfff] text-center">
        A lightweight task manager tailored for students: quickly add tasks,
        mark them complete, edit or delete entries and filter by completed or
        pending status. Built for speed, clarity and learning.
      </p>
      <span class="flex flex-col gap-6">
        <span class="flex flex-row gap-6 items-center">
          <img class="h-10" src="/media/component_2.svg" alt="icon" />
          <span>
            <h1>Add Tasks</h1>
            <p>
              Create assignments, due dates and priority notes in seconds.
            </p>
          </span>
        </span>
        <span class="flex flex-row gap-6 items-center">
          <img class="h-10" src="/media/component_3.svg" alt="icon" />
          <span>
            <h1>Mark Tasks Completed</h1>
            <p>Strike-through completed work and keep a tidy list.</p>
          </span>
        </span>
        <span class="flex flex-row gap-6 items-center">
          <img class="h-10" src="/media/component_4.svg" alt="icon" />
          <span>
            <h1>Edit/Delete</h1>
            <p>Quickly update task details or remove obsolete items.</p>
          </span>
        </span>
        <span class="flex flex-row gap-6 items-center">
          <img class="h-10" src="/media/component_5.svg" alt="icon" />
          <span>
            <h1>Filter by completed / pending</h1>
            <p>Focus on what matters with simple filters.</p>
          </span>
        </span>
      </span>
      <span class="flex flex-row gap-6"><button
          class="bg-[#fff] text-black p-2 rounded-xl justify-center items-center">Get Started</button>
    </div>
  </section>
  <section class="flex flex-col h-full" id="adbanner">
    <div class="flex-1 text-[75px] text-center lg:text-[250px] lg:text-left">STUDY</div>
    <div class="flex-1 text-[75px] text-center lg:text-[250px] lg:text-right">FLOW</div>
  </section>
  <footer class="bg-[#2b2b2b] rounded-2xl flex flex-col p-4 gap-4">
    <h1 class=" w-full text-center text-2xl">
      CONNECT WITH DEVELOPERS
    </h1>
    <div class="flex flex-col lg:flex-row p-4 gap-4">
      <span class="flex bg-[#000] gap-4 flex-1 items-center text-2xl rounded-xl"
        onclick="location.href='https://www.linkedin.com/in/yogesh-adhikari-986290323/?lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_contact_details%3B%2FKxLO55URAGYINoshq5vUA%3D%3D'">
        <img src="/media/linkedin.svg" alt="Linkedin" class="h-20">
        <h1>Yogesh Adhikari</h1>
      </span>
      <span class="flex bg-[#000] gap-4 flex-1 items-center text-2xl rounded-xl"
        onclick="location.href='https://www.linkedin.com/in/bipin-joshi-532284323/?lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_contact_details%3BhkPBgt0FSx6wgjqQQgMZwA%3D%3D'">
        <img src="/media/linkedin.svg" alt="Linkedin" class="h-20">
        <h1>Bipin Joshi</h1>
      </span>
    </div>
  </footer>
</body>
</html>