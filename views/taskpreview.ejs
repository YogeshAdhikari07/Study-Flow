<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Flow-Task</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/index.css">
</head>

<body class="h-screen w-screen overflow-hidden bg-[#0b0b0c] text-white flex flex-col p-6 gap-6">
    <div class="flex flex-row justify-between items-center ">
        <span><h1>Task Preview</h1></span>
        <%if(taskData.status === 'pending' || taskData.status === 'hold'){%>
            <button class="p-2 bg-white text-black" id="startWorkingBtn" onclick="updateStatus('<%=taskData._id%>','working')">Start Working</button>
            <span class="flex flex-row gap-6 hidden" id="completeHoldBtn">
                <button class="p-2 bg-white text-black" onclick="updateStatus('<%=taskData._id%>','hold')">Hold Task</button>
                <button class="p-2 bg-white text-black" onclick="updateStatus('<%=taskData._id%>','complete')">Complete Task</button>
            </span>
        <%}else if(taskData.status === 'working'){%>
            <button class="p-2 bg-white text-black hidden" id="startWorkingBtn" onclick="updateStatus('<%=taskData._id%>','working')">Start Working</button>
            <span class="flex flex-row gap-6" id="completeHoldBtn">
                <button class="p-2 bg-white text-black" onclick="updateStatus('<%=taskData._id%>','hold')">Hold Task</button>
                <button class="p-2 bg-white text-black" onclick="updateStatus('<%=taskData._id%>','complete')">Complete Task</button>
        <%}else{%>

        <%}%>
    </div>
    <div class="w-full flex flex-col lg:flex-row gap-6">
        <div class="flex flex-col gap-2 w-full">
            <h1>Title</h1>
            <span class="bg-[#242424] w-full p-4 rounded-xl">
                <%=taskData.title%>
            </span>
        </div>
        <div class="flex flex-col gap-2 w-full">
            <h1>Description</h1>
            <span class="bg-[#242424] w-full p-4 rounded-xl">
                <%=taskData.description%>
            </span>
        </div>
    </div>
    <div class="w-full flex flex-col lg:flex-row gap-6">
        <div class="flex flex-col gap-2 w-full">
            <h1>Priority</h1>
            <span class="bg-[#242424] w-full p-4 rounded-xl">
                <%=taskData.priority%>
            </span>
        </div>
        <div class="flex flex-col gap-2 w-full">
            <h1>Effort</h1>
            <span class="bg-[#242424] w-full p-4 rounded-xl">
                <%=taskData.effort%>
            </span>
        </div>
        <div class="flex flex-col gap-2 w-full">
            <h1>status</h1>
            <span class="bg-[#242424] w-full p-4 rounded-xl" id="statusMessage">
                <%=taskData.status%>
            </span>
        </div>
    </div>
    <script src="/javascript/taskpreview.js"></script>
</body>
</html>