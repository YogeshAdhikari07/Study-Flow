<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Studyt Flow-Sign</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/home.css">
</head>

<body class="h-screen w-screen overflow-x-hidden flex bg-[#0b0b0c] text-white">
    <section id="hero" role="form" class="h-full w-full flex justify-center items-center flex-col">
        <div class="bg-[#2b2b2b] p-2 flex justify-center items-center flex-col rounded-xl">
            <h1 class="p-4 border-b-2 text-3xl font-bold text-center">STUDY FLOW</h1>
            <form action="/api/login" method="post" id="loginForm" class="flex flex-col gap-4 p-2">
                <label for="displayname">Display Name :</label>
                <input type="text" name="displayname" id="displayname" autocomplete="username" placeholder="DISPLAY NAME" required="required" class="p-2 flex justify-center outline-none border-1 border-[#ff6b00]">
                <label for="email">email :</label>
                <input type="email" name="email" id="email" autocomplete="email" placeholder="EMAIL" required="required" class="p-2 flex justify-center outline-none border-1 border-[#ff6b00]">
                <label for="password">password</label>
                <input type="password" name="password" id="password" autocomplete="current-password" placeholder="password" required="required" class="p-2 flex justify-center outline-none border-1 border-[#ff6b00]">
                <button class="bg-white text-black p-4 flex justify-center items-center rounded-2xl hover:bg-[#ff6b00]" onclick="location.href='/page/Login'">Sign Up</button>
                <span>Do have an accout <a class="text-[#ff6b00]" href="/page/login">Login</a></span>
            </form>
        </div>
    </section>
</body>

</html>