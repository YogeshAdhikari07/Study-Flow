<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Flow</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/css/index.css">
</head>

<body class="h-screen w-screen overflow-x-hidden bg-[#0b0b0c] text-white flex flex-row p-6 gap-6">
    <section id="menu" role="menu"
        class="border-2 border-[#575656] rounded-xl hidden lg:w-[250px] lg:flex p-4 gap-4 flex-col">
        <div class="flex flex-col flex-1 gap-2">
            <span class="flex flex-row gap-2"><img src="/media/dashboard.svg" alt="Dashboard" class="h-6">
                <h1>DashBoard</h1>
            </span>
            <span class="flex flex-row gap-2"><img src="/media/notes.svg" alt="Tasks" class="h-6">
                <h1>Tasks</h1>
            </span>
            <span class="flex flex-row gap-2"><img src="/media/stats.svg" alt="Stats" class="h-6">
                <h1>Stats</h1>
            </span>
        </div>
        <div class="flex flex-col gap-2">
            <span class="flex flex-row items-center gap-2"><img src="/media/setting.svg" alt="Setting" class="h-6">
                <h1>Setting</h1>
            </span>
            <span class="flex flex-row gap-2"><img src="/media/logout.svg" alt="Logout" class="h-6">
                <h1>Logout</h1>
            </span>
        </div>
    </section>
    <section id="hero" class="flex-1 flex flex-col ">
        <div class="flex flex-row justify-between">
            <h1>Study Flow</h1>
            <span class="flex flex-row items-center gap-2">
                <img src="/media/user.svg" alt="User" class="h-8">
                <h1>User</h1>
            </span>
        </div>
        <div class="flex-1 flex flex-row gap-2">
            <section id="hero-main" class="flex-1">
asa
            </section>
            <section class="w-[250px]">
asas
            </section>
        </div>
    </section>
</body>

</html>